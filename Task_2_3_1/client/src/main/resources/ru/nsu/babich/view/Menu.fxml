<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="ru.nsu.babich.client.presentation.view.controller.MenuController"
            style="
                -fx-background-color: linear-gradient(to bottom right, #1f2937, #111827);
            ">

    <center>
        <VBox alignment="CENTER" spacing="30"
              style="-fx-padding: 50;">

            <Label text="SNAKE GAME"
                   style="
                        -fx-text-fill: white;
                        -fx-font-size: 34px;
                        -fx-font-weight: bold;
                        -fx-letter-spacing: 2px;
                   "/>

            <VBox alignment="CENTER" spacing="10"
                  style="
                        -fx-padding: 20 30;
                        -fx-background-color: rgba(255,255,255,0.05);
                        -fx-background-radius: 16;
                  ">

                <Label text="Food"
                       style="
                            -fx-text-fill: #cbd5e1;
                            -fx-font-size: 14px;
                            -fx-font-weight: bold;
                       "/>

                <Label text="■ Normal food"
                       style="
                            -fx-text-fill: #ff5c7a;
                            -fx-font-size: 13px;
                       "/>

                <Label text="■ Bonus"
                       style="
                            -fx-text-fill: #ffd166;
                            -fx-font-size: 13px;
                       "/>

                <Label text="■ Poison"
                       style="
                            -fx-text-fill: #a855f7;
                            -fx-font-size: 13px;
                       "/>

            </VBox>

            <VBox style="-fx-padding: 10 0 0 0;"/>

            <Button text="Start game"
                    onAction="#startGame"
                    style="
                        -fx-background-color: #3b82f6;
                        -fx-text-fill: white;
                        -fx-font-size: 16px;
                        -fx-font-weight: 600;
                        -fx-padding: 12 32;
                        -fx-background-radius: 14;
                        -fx-cursor: hand;

                        -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.35), 12, 0.2, 0, 4);
                    "/>

        </VBox>
    </center>

</BorderPane>